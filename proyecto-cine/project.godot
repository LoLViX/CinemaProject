; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="PoryectoCine"
run/main_scene="uid://dj5mvm8lg7mo0"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://Icons/icon.svg"

[autoload]

TextDB="*res://Scripts/Core/TextDB.gd"
DebugConfig="*res://Scripts/Core/DebugConfig.gd"
TagDB="*res://Scripts/Game/TagDB.gd"
CustomerDB="*res://Scripts/Customer/CustomerDB.gd"
DayPlanDB="*res://Scripts/Core/DayPlanDB.gd"
RunState="*res://Scripts/Game/RunState.gd"
MatchingSystemAuto="*res://Scripts/Game/MatchingSystem.gd"
SoundManager="*res://Scripts/Core/SoundManager.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_mcp/plugin.cfg")

[input]

serve_next={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":69,"key_label":0,"unicode":101,"location":0,"echo":false,"script":null)
]
